    {
      "id": "ZbqPmEmhCbh_GRn1KpMmH",
      "type": "text",
      "x": -1146.682149682054,
      "y": 553.9390817072593,
      "width": 577.5039672851562,
      "height": 100,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aQ",
      "roundness": null,
      "seed": 25198061,
      "version": 681,
      "versionNonce": 1803584102,
      "isDeleted": true,
      "boundElements": [],
      "updated": 1780858733030,
      "link": null,
      "locked": false,
      "text": "Fase 1 — você dá o contexto. O Claude ainda só recebe.\nFase 2 — ele entrega de verdade: artefato visual, não texto.\nFase 3 — o artefato é vivo: muda de método e atualiza na hora.\nFase 4 — ensina uma vez, repete sempre. Sai do \"fazer\" pro \"automatizar\".\nFase 5 — saiu do chat e entrou no seu sistema real.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Fase 1 — você dá o contexto. O Claude ainda só recebe.\nFase 2 — ele entrega de verdade: artefato visual, não texto.\nFase 3 — o artefato é vivo: muda de método e atualiza na hora.\nFase 4 — ensina uma vez, repete sempre. Sai do \"fazer\" pro \"automatizar\".\nFase 5 — saiu do chat e entrou no seu sistema real.",
      "autoResize": true,
      "lineHeight": 1.25
    },
